# TCP Tunnel Relay Server — Environment Variables
# Copy this file to .env and fill in your values

# Port to listen on (Railway/Fly.io set this automatically)
PORT=8080

# Shared secret token — must match what Flutter app and Agent use
# Change this to a strong random string in production!
AUTH_TOKEN=your-strong-secret-token-here

# Logging level: debug | info | warn | error
LOG_LEVEL=info
